---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---

<Layout title={`${post.data.title} — Philip Ludington`} description={post.data.description}>
  <main class="mx-auto max-w-2xl px-6 pb-24 pt-20">
    <a href="/blog" class="text-sm text-slate-500 transition hover:text-slate-800">&larr; Writing</a>

    <article class="mt-8">
      <header class="mb-10">
        <time datetime={post.data.date.toISOString()} class="text-sm text-slate-500">
          {fmt(post.data.date)}
        </time>
        <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-900">{post.data.title}</h1>
        {post.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs text-slate-600">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="post-body">
        <Content />
      </div>
    </article>

    <footer class="mt-16 border-t border-slate-200 pt-8 text-sm text-slate-500">
      <a href="/blog" class="transition hover:text-slate-800">&larr; More writing</a>
    </footer>
  </main>
</Layout>

<style>
  .post-body {
    color: #334155; /* slate-700 */
    font-size: 1.125rem;
    line-height: 1.75;
  }
  .post-body :global(p),
  .post-body :global(ul),
  .post-body :global(ol),
  .post-body :global(pre),
  .post-body :global(blockquote) {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }
  .post-body :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #0f172a; /* slate-900 */
  }
  .post-body :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: #0f172a;
  }
  .post-body :global(a) {
    color: #0f172a;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: #cbd5e1; /* slate-300 */
    transition: text-decoration-color 0.15s;
  }
  .post-body :global(a:hover) {
    text-decoration-color: #0f172a;
  }
  .post-body :global(strong) {
    color: #0f172a;
    font-weight: 600;
  }
  .post-body :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
  }
  .post-body :global(ol) {
    list-style: decimal;
    padding-left: 1.5rem;
  }
  .post-body :global(li) {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
  }
  .post-body :global(li)::marker {
    color: #94a3b8; /* slate-400 */
  }
  .post-body :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.875em;
    background: #f1f5f9; /* slate-100 */
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
  }
  .post-body :global(pre) {
    background: #0f172a; /* slate-900 */
    color: #e2e8f0; /* slate-200 */
    padding: 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .post-body :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }
  .post-body :global(hr) {
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
    border: 0;
    border-top: 1px solid #e2e8f0; /* slate-200 */
  }
  .post-body :global(blockquote) {
    border-left: 3px solid #cbd5e1;
    padding-left: 1rem;
    color: #475569; /* slate-600 */
    font-style: italic;
  }
  .post-body :global(em) {
    color: #475569;
  }
</style>
