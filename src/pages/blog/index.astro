---
import Layout from '../../layouts/Layout.astro'
import { getPublishedPosts, formatPostDate as fmt } from '../../lib/blog'

const posts = await getPublishedPosts()
---

<Layout
  title="Writing — Philip Ludington"
  description="Essays on building reliable software with coding agents, developer tooling, and AI-assisted engineering."
>
  <main class="mx-auto max-w-3xl px-6 pb-24 pt-20">
    <a href="/" class="text-sm text-slate-500 transition hover:text-slate-800">&larr; Philip Ludington</a>

    <h1 class="mt-6 text-4xl font-bold tracking-tight text-slate-900">Writing</h1>
    <p class="mt-3 text-lg text-slate-600">
      Notes on building reliable software with coding agents, developer tooling, and the craft of
      AI-assisted engineering.
    </p>

    <ul class="mt-12 space-y-10">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="group block">
            <time datetime={post.data.date.toISOString()} class="text-sm text-slate-500">
              {fmt(post.data.date)}
            </time>
            <h2 class="mt-1 text-2xl font-semibold text-slate-900 group-hover:text-slate-700">
              {post.data.title}
              <span class="ml-1 inline-block text-slate-400 transition group-hover:translate-x-0.5">&rarr;</span>
            </h2>
            <p class="mt-2 text-slate-600">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>

    {posts.length === 0 && (
      <p class="mt-12 text-slate-500">Nothing published yet — check back soon.</p>
    )}
  </main>
</Layout>
