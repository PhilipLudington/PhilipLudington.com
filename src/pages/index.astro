---
import Layout from '../layouts/Layout.astro'

const projects = [
  {
    name: 'ChangeSmith',
    url: 'https://changesmith.dev',
    description:
      'Automated changelog generation that turns your commit history into polished, readable release notes.',
  },
  {
    name: 'SheetSmith',
    url: 'https://sheetsmith.dev',
    description:
      'A fast, privacy-first CSV editor built for people who work with data every day.',
  },
  {
    name: 'GameLegend',
    url: 'https://gamelegend.com',
    description:
      'Curated retro gaming content celebrating the history and craft of classic video games.',
  },
  {
    name: 'MrPhilGames',
    url: 'https://mrphilgames.com',
    description:
      'Game development blog and studio — experiments, devlogs, and released titles.',
  },
]

const experience = [
  {
    role: 'Founder',
    org: 'Changesmith.dev',
    period: 'Dec 2025 — Present',
    bullets: [
      'Building AI-powered changelog automation that turns messy commit histories into polished release notes',
      'Solo-founded and built with Next.js, TypeScript, and Claude API',
    ],
  },
  {
    role: 'Game Director',
    org: 'Mr. Phil Games',
    period: 'Dec 2024 — Present',
    bullets: [
      'Directing two original indie titles: Crimson Crisis (sci-fi co-op roguelike) and Stellar Throne (4X strategy, Godot 4.4 + Zig)',
      'Pioneering "Agentic Game Development" — integrating AI-assisted workflows with human creative direction',
    ],
  },
  {
    role: 'Senior Software Engineer',
    org: 'Ainsworth Game Technology',
    period: 'Oct 2023 — Nov 2024',
    bullets: [
      'Built high-performance gaming software and innovative slot and casino products for global markets',
    ],
  },
  {
    role: 'Senior Software Engineer',
    org: 'Boss Fight Entertainment',
    period: 'Jun 2020 — Jul 2021',
    bullets: [
      'Unity/C# development for MyVegas Bingo and Kingdom Boss — telemetry, gameplay, and UX systems',
      'Mentored engineers through code reviews, pair programming, and coding challenges',
    ],
  },
  {
    role: 'Senior Unity Developer',
    org: 'Cerberus Interactive',
    period: 'Aug 2019 — May 2020',
    bullets: [
      'Gameplay developer for Atlas Empires, a location-based mobile game with IoC, dependency injection, and Protocol Buffers',
    ],
  },
  {
    role: 'Senior Software Engineer',
    org: 'Zynga',
    period: 'Jul 2015 — Jun 2018',
    bullets: [
      'Gameplay, feature, and infrastructure development for the slots division — Hit It Rich, Spin It Rich, Black Diamond Casino',
      'Built CI pipelines for iOS, Android, macOS, and Windows along with internal testing harness',
    ],
  },
  {
    role: 'Software Engineer',
    org: 'IGT',
    period: 'May 2013 — Jul 2015',
    bullets: [
      'Developed premium casino games at Studio 1A using Unity3D on IGT\'s proprietary Ascent Platform',
    ],
  },
  {
    role: 'Solutions Engineer',
    org: 'Eastport Analytics',
    period: 'Apr 2009 — May 2013',
    bullets: [
      'Full lifecycle development for clients in media, satellite operations, drug manufacturing, and law enforcement',
      'ETL pipelines, competitive intelligence platforms, and data science using ASP.NET, C#, SQL Server, and AWS',
    ],
  },
  {
    role: 'Consulting Services Specialist',
    org: 'AT&T Government Solutions',
    period: 'Sep 2003 — Jun 2007',
    bullets: [
      'Designed and maintained applications for the U.S. Army using C++, C#, ASP.NET, and SQL Server',
    ],
  },
  {
    role: 'Developer',
    org: 'Procurement Automation Institute / SAP',
    period: 'Sep 1999 — Sep 2003',
    bullets: [
      'Developed Document Builder integrating with SAP R/3, SRM, and Enterprise Buyer using C/C++, Java, and ABAP',
    ],
  },
]

const education = [
  {
    school: 'University of Maryland at College Park',
    degree: 'B.S., Logistics, Materials, and Supply Chain Management',
    period: '1991 — 1998',
  },
  {
    school: 'Mississippi School for Mathematics and Science',
    degree: 'Diploma, Computers',
    period: '1989 — 1991',
  },
]

const skills = [
  'TypeScript',
  'C#',
  'Unity',
  'Godot',
  'Claude Code',
  'AI/LLM Integration',
  'C/C++',
  'JavaScript',
  'React',
  'Next.js',
  'Astro',
  'Node.js',
  'Zig',
  'Git',
  'ASP.NET',
  'SQL Server',
  'AWS',
  'iOS & Android',
]
---

<Layout>
  <!-- Hero -->
  <section class="flex min-h-[80vh] flex-col items-center justify-center px-6 text-center">
    <h1 class="text-5xl font-bold tracking-tight text-slate-900 sm:text-6xl">
      Philip Ludington
    </h1>
    <p class="mt-4 max-w-xl text-xl text-slate-600">
      Game Developer &amp; AI Tools Creator. Building games and developer tools with AI.
    </p>
    <div class="mt-8 flex gap-4">
      <a
        href="#contact"
        class="rounded-lg bg-slate-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-slate-700"
      >
        Get in touch
      </a>
      <a
        href="#projects"
        class="rounded-lg border border-slate-300 px-6 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50"
      >
        See my work
      </a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="mx-auto max-w-3xl px-6 py-24">
    <h2 class="text-3xl font-bold text-slate-900">About</h2>
    <div class="mt-6 space-y-4 text-lg leading-relaxed text-slate-600">
      <p>
        I'm a software engineer with 25+ years of experience spanning game development, AI-powered
        developer tools, enterprise software, and government systems. I've shipped casino games at
        Zynga, IGT, and Ainsworth, directed indie titles at Mr. Phil Games, and founded Changesmith.dev.
      </p>
      <p>
        I believe in what I call Agentic Development — integrating AI-assisted workflows with human
        creative direction to let small teams build with the efficiency of a studio. Based in Austin, TX.
      </p>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="bg-slate-50 px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-3xl font-bold text-slate-900">Projects</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {projects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-xl border border-slate-200 bg-white p-6 transition hover:border-slate-300 hover:shadow-md"
          >
            <h3 class="text-xl font-semibold text-slate-900 group-hover:text-slate-700">
              {project.name}
              <span class="ml-1 inline-block text-slate-400 transition group-hover:translate-x-0.5">
                &rarr;
              </span>
            </h3>
            <p class="mt-2 text-slate-600">{project.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="mx-auto max-w-3xl px-6 py-24">
    <h2 class="text-3xl font-bold text-slate-900">Experience</h2>
    <div class="mt-10 space-y-10">
      {experience.map((job) => (
        <div>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-lg font-semibold text-slate-900">{job.role}</h3>
            <span class="text-sm text-slate-500">{job.period}</span>
          </div>
          <p class="text-slate-600">{job.org}</p>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-slate-600">
            {job.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Skills -->
    <div class="mt-16">
      <h3 class="text-lg font-semibold text-slate-900">Skills</h3>
      <div class="mt-4 flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700">
            {skill}
          </span>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div class="mt-16">
      <h3 class="text-lg font-semibold text-slate-900">Education</h3>
      <div class="mt-4 space-y-4">
        {education.map((edu) => (
          <div>
            <div class="flex flex-wrap items-baseline justify-between gap-x-4">
              <span class="font-medium text-slate-900">{edu.school}</span>
              <span class="text-sm text-slate-500">{edu.period}</span>
            </div>
            <p class="text-slate-600">{edu.degree}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="bg-slate-50 px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-slate-900">Get in Touch</h2>
      <p class="mt-4 text-lg text-slate-600">
        Interested in working together? I'd love to hear from you.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="mailto:philip@philipludington.com"
          class="rounded-lg bg-slate-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-slate-700"
        >
          philip@philipludington.com
        </a>
      </div>
      <div class="mt-6 flex justify-center gap-6 text-slate-500">
        <a
          href="https://github.com/PhilipLudington"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-slate-800"
        >
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/philipludington"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-slate-800"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="px-6 py-8 text-center text-sm text-slate-400">
    &copy; {new Date().getFullYear()} Philip Ludington
  </footer>
</Layout>
