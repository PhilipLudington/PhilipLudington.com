---

<Layout>
  <!-- Hero -->
  <section class="flex flex-col items-center px-6 pb-12 pt-20 text-center">
    <h1 class="text-5xl font-bold tracking-tight text-slate-900 sm:text-6xl">
      Philip Ludington
    </h1>
    <p class="mt-4 max-w-2xl text-xl text-slate-600">
      I ship AI-native developer tools.
    </p>
    <p class="mt-2 max-w-2xl text-base text-slate-500">
      25+ years of software engineering. Claude Code, MCP, and agents native.
    </p>
    <p class="mt-4 inline-flex items-center rounded-full bg-emerald-50 px-4 py-1.5 text-sm font-medium text-emerald-700 ring-1 ring-emerald-200">
      Available for fractional, contract, or full-time engagements
    </p>
    <div class="mt-8 flex gap-4">
      <a
        href="#contact"
        class="rounded-lg bg-slate-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-slate-700"
      >
        Get in touch
      </a>
      <a
        href="#projects"
        class="rounded-lg border border-slate-300 px-6 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:bg-slate-50"
      >
        See my work
      </a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="mx-auto max-w-3xl px-6 pb-24 pt-12">
    <h2 class="text-3xl font-bold text-slate-900">About</h2>
    <div class="mt-6 space-y-4 text-lg leading-relaxed text-slate-600">
      <p>
        Software engineer building AI-native developer tools. Past year's output:
        <strong>Changesmith</strong> (changelog SaaS), <strong>MCPAtlas</strong> (curated MCP server
        registry, 52 servers indexed), <strong>Klar</strong> (a programming language with its own
        compiler, designed for AI-assisted development), two curated AI-tool directories totaling
        150+ tools (<strong>AIDevTools</strong> + <strong>AgenticGameDevelopment</strong>), and
        <strong>Deep Hollow</strong> (Next.js + Solana AI-partner survival game).
      </p>
      <p>
        Before going independent, 25+ years of production software at companies including Zynga,
        IGT, SAP, and U.S. Army contractors. Native to Claude Code, MCP, and agent stacks. New
        products ship every 4–8 weeks. Based in Austin, TX.
      </p>
      <p class="border-l-4 border-emerald-300 bg-emerald-50/50 px-4 py-3 text-base">
        <strong class="text-slate-900">Currently available</strong> for fractional, contract, or
        full-time roles at AI-native developer tools companies. Side projects continue in parallel
        with explicit agreement.
      </p>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="bg-slate-50 px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-3xl font-bold text-slate-900">Featured Work</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {featuredProjects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-xl border border-slate-200 bg-white p-6 transition hover:border-slate-300 hover:shadow-md"
          >
            <h3 class="text-xl font-semibold text-slate-900 group-hover:text-slate-700">
              {project.name}
              <span class="ml-1 inline-block text-slate-400 transition group-hover:translate-x-0.5">
                &rarr;
              </span>
            </h3>
            <p class="mt-2 text-slate-600">{project.description}</p>
          </a>
        ))}
      </div>

      <h2 class="mt-20 text-2xl font-bold text-slate-900">More Projects</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {moreProjects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-300 hover:shadow-sm"
          >
            <h3 class="text-base font-semibold text-slate-900 group-hover:text-slate-700">
              {project.name}
              <span class="ml-1 inline-block text-slate-400 transition group-hover:translate-x-0.5">
                &rarr;
              </span>
            </h3>
            <p class="mt-2 text-sm text-slate-600">{project.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="mx-auto max-w-3xl px-6 py-24">
    <h2 class="text-3xl font-bold text-slate-900">Experience</h2>
    <div class="mt-10 space-y-10">
      {experience.map((job) => (
        <div>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4">
            <h3 class="text-lg font-semibold text-slate-900">{job.role}</h3>
            <span class="text-sm text-slate-500">{job.period}</span>
          </div>
          <p class="text-slate-600">{job.org}</p>
          <ul class="mt-3 list-disc space-y-1 pl-5 text-slate-600">
            {job.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Skills -->
    <div class="mt-16">
      <h3 class="text-lg font-semibold text-slate-900">Skills</h3>
      <div class="mt-4 flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700">
            {skill}
          </span>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div class="mt-16">
      <h3 class="text-lg font-semibold text-slate-900">Education</h3>
      <div class="mt-4 space-y-4">
        {education.map((edu) => (
          <div>
            <div class="flex flex-wrap items-baseline justify-between gap-x-4">
              <span class="font-medium text-slate-900">{edu.school}</span>
              <span class="text-sm text-slate-500">{edu.period}</span>
            </div>
            <p class="text-slate-600">{edu.degree}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="bg-slate-50 px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-slate-900">Get in Touch</h2>
      <p class="mt-4 text-lg text-slate-600">
        Currently available for fractional, contract, or full-time roles at AI-native developer tools
        companies. Side projects continue in parallel.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="mailto:philip@philipludington.com"
          class="rounded-lg bg-slate-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-slate-700"
        >
          philip@philipludington.com
        </a>
      </div>
      <div class="mt-6 flex justify-center gap-6 text-slate-500">
        <a
          href="https://github.com/PhilipLudington"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-slate-800"
        >
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/philipludington"
          target="_blank"
          rel="noopener noreferrer"
          class="transition hover:text-slate-800"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="px-6 py-8 text-center text-sm text-slate-400">
    &copy; {new Date().getFullYear()} Philip Ludington
  </footer>
</Layout>
